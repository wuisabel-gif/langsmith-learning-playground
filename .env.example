# ---- Required: OpenAI ----
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Default models (override if you like)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- LangSmith tracing (real observability) ----
# Get a key at https://smith.langchain.com/ -> Settings -> API Keys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=agent-engineering-lab
# US: https://api.smith.langchain.com  |  EU: https://eu.api.smith.langchain.com
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- Server ----
PORT=3000
